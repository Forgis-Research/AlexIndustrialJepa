# Environment variables for IndustrialJEPA
# Copy to .env and fill in your values
# DO NOT COMMIT .env - only .env.example

# WandB API Key (https://wandb.ai/settings)
WANDB_API_KEY=your_wandb_key_here

# HuggingFace token (https://huggingface.co/settings/tokens)
# Needs WRITE access for uploading datasets
HF_TOKEN=hf_your_token_here

# Anthropic API Key (for Claude Code)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# TabPFN API Key (optional)
TABPFN_API_KEY=your_tabpfn_key_here

# Kaggle credentials (optional)
KAGGLE_API_TOKEN=your_kaggle_token_here
KAGGLE_USERNAME=your_username

# HuggingFace dataset repository for mechanical components
HF_DATASET_REPO=Forgis/Mechanical-Components
