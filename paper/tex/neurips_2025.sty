% NeurIPS 2025 Style (simplified version)
% Based on standard NeurIPS formatting guidelines

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 style]

% Options
\newif\if@final\@finalfalse
\DeclareOption{final}{\@finaltrue}
\DeclareOption{preprint}{\@finalfalse}
\ProcessOptions\relax

% Page layout
\RequirePackage[margin=1in]{geometry}
\RequirePackage{times}
\RequirePackage{fancyhdr}
\RequirePackage{natbib}

% Fonts
\renewcommand{\rmdefault}{ptm}
\renewcommand{\sfdefault}{phv}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\paragraph}[runin]{\normalsize\bfseries}{}{}{}[.]

% Abstract formatting
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \begin{quote}%
}{%
  \end{quote}%
}

% Title and author
\renewcommand{\maketitle}{%
  \begin{center}%
    {\LARGE\bfseries\@title\par}%
    \vskip 1.5em%
    {\large\@author\par}%
    \vskip 1em%
  \end{center}%
  \par%
}

% Line spacing
\linespread{1.0}

% No page numbers in preprint
\if@final
  \pagestyle{fancy}
  \fancyhf{}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
\else
  \pagestyle{empty}
\fi

\endinput
